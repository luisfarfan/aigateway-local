# ─── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=false                   # true in production (structured JSON logs)

# ─── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Comma-separated list of valid API keys for client authentication.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEYS=your-secret-api-key-here,optional-second-key

# Rate limiting (requests per minute per API key)
RATE_LIMIT_PER_MINUTE=120

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=local_ai_gateway
POSTGRES_USER=gateway
POSTGRES_PASSWORD=gateway_secret

# Async DSN — built from the above by config.py, or override directly:
# DATABASE_URL=postgresql+asyncpg://gateway:gateway_secret@localhost:5432/local_ai_gateway

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                  # empty = no auth (fine for local)
REDIS_DB=0

# SSE pub/sub channel TTL in seconds (events expire after job is done)
REDIS_CHANNEL_TTL=3600

# ─── MinIO / Object Storage ───────────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=local-ai-gateway
MINIO_REGION=us-east-1
# Presigned URL expiry for artifact download links (seconds)
MINIO_PRESIGNED_EXPIRY=86400

# ─── ARQ / Queue ──────────────────────────────────────────────────────────────
# Max jobs running simultaneously across all workers
QUEUE_GLOBAL_CONCURRENCY=4

# Max concurrent jobs per modality (prevents VRAM contention)
QUEUE_TEXT_CONCURRENCY=4
QUEUE_AUDIO_CONCURRENCY=2
QUEUE_IMAGE_CONCURRENCY=1
QUEUE_VIDEO_CONCURRENCY=1
QUEUE_PIPELINE_CONCURRENCY=1

# Default job timeout (seconds) when not specified per-job
JOB_DEFAULT_TIMEOUT=3600

# ARQ job result TTL in Redis (seconds)
ARQ_RESULT_TTL=86400

# Heartbeat interval for long-running jobs (seconds)
WORKER_HEARTBEAT_INTERVAL=15

# ─── Workers ──────────────────────────────────────────────────────────────────
# Which modalities this worker instance handles (comma-separated)
# Used when launching a specific worker: python -m workers.main --modality image
WORKER_MODALITIES=text,audio,image,video,pipeline

# Unique ID for this worker instance (auto-generated if empty)
WORKER_ID=

# ─── Provider feature flags ───────────────────────────────────────────────────
# Set to "true" on the Ubuntu machine to enable real AI engines.
# On dev/Mac leave everything false — stub provider handles all requests.
ENABLE_PROVIDER_STUB=true
ENABLE_PROVIDER_DIFFUSERS=false
ENABLE_PROVIDER_LOCAL_LLM=false
ENABLE_PROVIDER_LOCAL_TTS=false

# ─── Diffusers model paths ────────────────────────────────────────────────────
# If set, uses local path instead of downloading from HuggingFace Hub.
# Convention: DIFFUSERS_MODEL_PATH_{MODEL_ID_UPPERCASED}
# Example (Ubuntu machine with models already downloaded):
# DIFFUSERS_MODEL_PATH_STABLE_DIFFUSION_XL=/data/models/stable-diffusion-xl-base-1.0
# DIFFUSERS_MODEL_PATH_STABLE_DIFFUSION_V1_5=/data/models/stable-diffusion-v1-5
# DIFFUSERS_MODEL_PATH_SDXL_TURBO=/data/models/sdxl-turbo

# ─── Local LLM ────────────────────────────────────────────────────────────────
# Backend: "ollama" (default) | "transformers"
LOCAL_LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434
# Local path overrides per model (optional):
# LOCAL_LLM_PATH_LLAMA3_HF=/data/models/llama3-8b-instruct

# ─── Local TTS ────────────────────────────────────────────────────────────────
# Engine: "xtts" | "kokoro" | "piper"
LOCAL_TTS_ENGINE=xtts
# XTTS_MODEL_PATH=/data/models/xtts_v2
# PIPER_MODELS_DIR=/data/models/piper
