{
  "id": null,
  "uid": "local-ai-gateway",
  "title": "Local AI Gateway",
  "tags": ["ai", "local", "gateway"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Jobs Completed",
      "description": "Total jobs that finished successfully (all time).",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "sum(gateway_jobs_total{status=\"completed\"}) or vector(0)",
          "legendFormat": "Completed",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Active Jobs",
      "description": "Jobs currently running in a provider right now.",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "sum(gateway_active_jobs) or vector(0)",
          "legendFormat": "Running",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Queue Depth",
      "description": "Jobs waiting to be picked up by a worker.",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "sum(gateway_queue_depth) or vector(0)",
          "legendFormat": "Queued",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Success Rate (10m)",
      "description": "Percentage of jobs completing successfully in the last 10 minutes.",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "100 * sum(rate(gateway_jobs_total{status=\"completed\"}[10m])) / (sum(rate(gateway_jobs_total[10m])) > 0) or vector(100)",
          "legendFormat": "Success %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Job Throughput (rate / 5 min)",
      "description": "Jobs completing per second, grouped by final status.",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "expr": "sum by (status) (rate(gateway_jobs_total[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": false }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "completed" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "failed" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "retried" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          }
        ]
      }
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Active Jobs by Provider",
      "description": "How many jobs each provider is executing right now, over time.",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "expr": "sum by (provider) (gateway_active_jobs)",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 20, "spanNulls": false }
        },
        "overrides": []
      }
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Inference Duration — p50 / p95 / p99",
      "description": "How long provider.execute() takes. p95/p99 reveal tail latency and stalls.",
      "gridPos": { "x": 0, "y": 12, "w": 16, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, provider) (rate(gateway_inference_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 — {{provider}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, provider) (rate(gateway_inference_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 — {{provider}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, provider) (rate(gateway_inference_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 — {{provider}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "spanNulls": false
          }
        },
        "overrides": []
      }
    },

    {
      "id": 8,
      "type": "bargauge",
      "title": "Queue Depth by Priority",
      "description": "Jobs waiting per ARQ priority queue (high / normal / low).",
      "gridPos": { "x": 16, "y": 12, "w": 8, "h": 8 },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "minVizWidth": 0,
        "minVizHeight": 10
      },
      "targets": [
        {
          "expr": "gateway_queue_depth",
          "legendFormat": "{{priority}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "continuous-BlPu" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "Jobs Failed (total)",
      "description": "Cumulative failed jobs over time — spikes = provider problems.",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 6 },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "expr": "sum by (job_type, provider) (gateway_jobs_total{status=\"failed\"})",
          "legendFormat": "{{job_type}} / {{provider}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        },
        "overrides": []
      }
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "Inference Duration by Job Type",
      "description": "Average inference time per job type — useful to spot slow model variants.",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 6 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "expr": "sum by (job_type) (rate(gateway_inference_duration_seconds_sum[5m])) / sum by (job_type) (rate(gateway_inference_duration_seconds_count[5m]))",
          "legendFormat": "avg — {{job_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        },
        "overrides": []
      }
    }

  ]
}
